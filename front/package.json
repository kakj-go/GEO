{
  "name": "superlink",
  "version": "1.0.2",
  "description": "SuperLink",
  "main": "public/electron.js",
  "homepage": "./",
  "author": "Your Name",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "build-react": "react-scripts build",
    "build-go": "node -e \"require('fs').mkdirSync('resources_ext',{recursive:true})\" && cd .. && go build -ldflags=\"-H windowsgui\" -o front/resources_ext/backend.exe ./cmd/app/main.go",
    "build-go-mac": "node -e \"require('fs').mkdirSync('resources_ext',{recursive:true})\" && cd .. && go build -o front/resources_ext/backend ./cmd/app/main.go",
    "dist-win": "npm run build-go && npm run build-react && electron-builder --win --x64",
    "dev": "npm run backup-release && npm run build-go && npm run build-react && electron-builder --win --x64",
    "electron": "electron public/electron.js",
    "start": "react-scripts start",
    "backup-release": "node scripts/backup_release.js",
    "restore-release": "node scripts/restore_release.js",
    "mac-ui": "npm run build-react && electron-builder --mac --arm64 --publish=never -c.productName=\"SuperLink-UI\" -c.extraMetadata.config.autoStartBackend=false",
    "win-ui": "npm run build-react && electron-builder --win --x64 --publish=never -c.productName=\"SuperLink-UI\" -c.extraMetadata.config.autoStartBackend=false"
  },
  "build": {
    "asar": true,
    "appId": "com.yourcompany.desktop-app",
    "productName": "SuperLink",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "build/**/*",
      "public/electron.js",
      "src/services/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": "app"
      },
      {
        "from": "src/services",
        "to": "services"
      },
      {
        "from": "node_modules/playwright-core",
        "to": "node_modules/playwright-core"
      },
      {
        "from": "node_modules/playwright",
        "to": "node_modules/playwright"
      },
      {
        "from": "node_modules/electron-log",
        "to": "node_modules/electron-log"
      },
      {
        "from": "node_modules/chrome-finder",
        "to": "node_modules/chrome-finder"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "resources_ext/backend.exe",
          "to": "backend.exe"
        }
      ]
    },
    "mac": {
      "category": "public.app-category.utilities",
      "extraResources": [
        {
          "from": "resources_ext/backend",
          "to": "backend"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SuperLink",
      "uninstallDisplayName": "SuperLink",
      "include": "installer.nsh"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@tiptap/extension-bubble-menu": "^3.20.1",
    "@tiptap/extension-color": "^3.20.1",
    "@tiptap/extension-highlight": "^3.20.1",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-task-item": "^3.20.1",
    "@tiptap/extension-task-list": "^3.20.1",
    "@tiptap/extension-text-style": "^3.20.1",
    "@tiptap/extension-underline": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@uiw/react-md-editor": "^4.0.11",
    "antd": "^5.29.3",
    "axios": "^1.13.2",
    "chrome-finder": "^1.0.7",
    "electron-log": "^5.4.3",
    "file-saver": "^2.0.5",
    "html-docx-js-typescript": "^0.1.5",
    "marked": "^17.0.4",
    "playwright": "^1.40.1",
    "playwright-core": "^1.56.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.6",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^23.6.0",
    "react-scripts": "5.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
