# ============================================
# SuperLink Docker 部署环境变量配置
# ============================================
# 复制此文件为 .env 并修改对应的配置项
# cp .env.docker .env

# ============================================
# MySQL 配置
# ============================================
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=llm_reference_matrix
MYSQL_PORT=3306
MYSQL_POOL_MAX=10

# ============================================
# 应用配置
# ============================================
APP_HOST=http://localhost:8080
HTTP_PORT=8080
LOG_LEVEL=info
DEBUG=false

# ============================================
# 安全配置
# ============================================
JWT_SECRET=your-secure-jwt-secret-change-me
JWT_WHITELISTROP=

# ============================================
# 第三方 API 配置
# ============================================
# APIMart API Key（必填，请填写你自己的密钥）
APIMART_API_KEY=

# ============================================
# 功能开关
# ============================================
METRICS_ENABLED=true
SWAGGER_ENABLED=false
